# Gateway
GATEWAY_PORT=3000

# JWT — identique dans tous les services qui valident des tokens
JWT_SECRET="change-this-to-a-long-random-secret"

# RabbitMQ
RABBITMQ_USER=admin
RABBITMQ_PASS=admin

# PostgreSQL (partagé entre les instances)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Logs : error | warn | info | debug
LOG_LEVEL=info
