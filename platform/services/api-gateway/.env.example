PORT=3000

# Doit être identique au JWT_SECRET des services auth
JWT_SECRET="change-this-to-a-long-random-secret"

# URLs internes Docker (nom du service Docker = hostname)
AUTH_SERVICE_URL=http://auth-service:3001
INVENTORY_SERVICE_URL=http://inventory-service:3002
MONITORING_SERVICE_URL=http://monitoring-service:3003
